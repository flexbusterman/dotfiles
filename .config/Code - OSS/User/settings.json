{
  "keyboard.dispatch": "keyCode",
  "editor.lineNumbers": "relative",
  "editor.autoIndent": "full",
  "window.zoomLevel": 1,
  "editor.minimap.enabled": false,
  "breadcrumbs.enabled": true,
  "workbench.startupEditor": "newUntitledFile",
  "window.menuBarVisibility": "toggle",
  "workbench.statusBar.visible": true,
  "workbench.activityBar.visible": false,
  "vim.easymotion": true,
  "vim.incsearch": true,
  "vim.useSystemClipboard": true,
  "terminal.integrated.confirmOnExit": false,
  "vim.useCtrlKeys": true,
  "vim.hlsearch": true,
  "vim.statusBarColorControl": true,
  "vim.statusBarColors.normal": [
    "#333333",
    "#ffffff"
  ],
  "vim.statusBarColors.insert": "#336633",
  "vim.statusBarColors.visual": "#550055",
  "vim.statusBarColors.visualline": "#550055",
  "vim.statusBarColors.visualblock": "#550055",
  "vim.statusBarColors.replace": "#D08770",
  "vim.statusBarColors.commandlineinprogress": "#007ACC",
  "vim.statusBarColors.searchinprogressmode": "#007ACC",
  "vim.statusBarColors.easymotionmode": "#007ACC",
  "vim.statusBarColors.easymotioninputmode": "#007ACC",
  "vim.statusBarColors.surroundinputmode": "#007ACC",
  "workbench.colorCustomizations": {
    "statusBar.background": "#333333",
    "statusBar.noFolderBackground": "#333333",
    "statusBar.debuggingBackground": "#333333",
    "statusBar.foreground": "#ffffff"
  },
  "workbench.colorTheme": "Dracula",
  "vim.commandLineModeKeyBindings": [],
  "editor.tabSize": 2,
  "vim.leader": ",",
  "vim.insertModeKeyBindings": [],
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": [
        "<leader>",
        "q"
      ],
      "commands": [
        "workbench.action.closeActiveEditor"
      ]
    },
    {
      "before": [
        "<leader>",
        "w"
      ],
      "commands": [
        "workbench.action.files.save"
      ]
    },
    {
      "before": [
        "<leader>",
        "."
      ],
      "commands": [
        ":nohl"
      ]
    },
    {
      "before": [
        "<leader>",
        "t"
      ],
      "commands": [
        "workbench.action.toggleSidebarVisibility"
      ]
    },
    {
      "before": [
        "<leader>",
        "c"
      ],
      "commands": [
        "editor.action.commentLine",
      ],
    },
    {
      "before": [
        "<leader>",
        "f"
      ],
      "commands": [
        "revealInExplorer",
      ],
    },
    {
      "before": [
        "<leader>",
        "r",
        "e"
      ],
      "commands": [
        "editor.action.rename"
      ]
    },
    {
      "before": [
        "<leader>",
        "r",
        "f"
      ],
      "commands": [
        "fileutils.renameFile"
      ]
    },
    {
      "before": [
        "<leader>",
        "o",
        "g"
      ],
      "commands": [
        "workbench.action.showAllSymbols"
      ]
    },
    {
      "before": [
        "<leader>",
        "o",
        "o"
      ],
      "commands": [
        "workbench.action.showEditorsInActiveGroup"
      ]
    },
    {
      "before": [
        "<leader>",
        "o",
        "p"
      ],
      "commands": [
        "workbench.action.quickOpen"
      ]
    }
  ],
  "vim.visualModeKeyBindings": [
    {
      "before": [
        "<leader>",
        "c"
      ],
      "commands": [
        "editor.action.commentLine",
        "extension.vim_escape"
      ],
    }
  ],
  "editor.highlightActiveIndentGuide": false,
  "editor.renderIndentGuides": false,
  "editor.renderLineHighlight": "none",
  "editor.occurrencesHighlight": false,
  "editor.matchBrackets": "never",
  "git.confirmSync": false,
  "editor.wordWrap": "on",
  "editor.fontFamily": "'Roboto Mono'",
  "debug.console.fontFamily": "'Roboto Mono'",
  "debug.console.fontSize": 14,
  "markdown.preview.fontFamily": "'Roboto Mono'",
  "markdown.preview.fontSize": 14,
  "terminal.integrated.fontFamily": "'Roboto Mono'",
  "terminal.integrated.fontSize": 14,
  "vim.easymotionMarkerFontSize": "14",
  "vim.easymotionMarkerFontFamily": "'Roboto Mono'",
  "zoombar.defaultZoom": 120,
  "editor.fontSize": 14,
  "vetur.format.defaultFormatter.js": "vscode-typescript",
  "explorer.confirmDelete": false
}